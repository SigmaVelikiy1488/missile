local CFG = {
    protocol = "missile",
    profileFile = "cargo_profile.txt",
    telemetryFile = "cargo_telemetry.log",

    cruiseMinAlt = 100,
    cruiseMaxAlt = 200,
    cruiseAlt = 150,

    launchTicks = 30,
    approachDist = 180,
    finalDist = 45,
    safeAlt = 70,
    finalOffset = 3,

    tick = 0.05,
    leadTime = 1.25,

    yawDead = 0.04,
    pitchDead = 0.03,

    cruiseRollLimit = 6,
    approachRollLimit = 10,
    finalRollLimit = 15,

    cruisePitchLimit = 6,
    approachPitchLimit = 12,
    finalPitchLimit = 15,

    thrLaunch = 13,
    thrCruise = 8,
    thrTurn = 6,
    thrFinal = 5,
    thrRecovery = 12,
    thrMax = 15,

    yawSmooth = 0.20,
    pitchSmooth = 0.18,
    velSmooth = 0.12,

    recoveryStallTicks = 24,
    recoveryMinSpeed = 0.12
}

local function clamp(v, a, b)
    if v < a then return a end
    if v > b then return b end
    return v
end

local function lerp(a, b, t)
    return a + (b - a) * t
end

local function lerpVec(a, b, t)
    return { x = lerp(a.x, b.x, t), y = lerp(a.y, b.y, t), z = lerp(a.z, b.z, t) }
end

local function wrapPi(a)
    while a > math.pi do a = a - math.pi * 2 end
    while a < -math.pi do a = a + math.pi * 2 end
    return a
end

local function vec(x, y, z)
    return { x = x, y = y, z = z }
end

local function vadd(a, b)
    return { x = a.x + b.x, y = a.y + b.y, z = a.z + b.z }
end

local function vsub(a, b)
    return { x = a.x - b.x, y = a.y - b.y, z = a.z - b.z }
end

local function vmul(a, s)
    return { x = a.x * s, y = a.y * s, z = a.z * s }
end

local function vlen(a)
    return math.sqrt(a.x * a.x + a.y * a.y + a.z * a.z)
end

local function vnorm(a)
    local l = vlen(a)
    if l == 0 then return { x = 0, y = 0, z = 0 } end
    return { x = a.x / l, y = a.y / l, z = a.z / l }
end

local function vdot(a, b)
    return a.x * b.x + a.y * b.y + a.z * b.z
end

local function quatConj(q)
    return { a = q.a, v = { x = -q.v.x, y = -q.v.y, z = -q.v.z } }
end

local function quatMul(q1, q2)
    local a1, x1, y1, z1 = q1.a, q1.v.x, q1.v.y, q1.v.z
    local a2, x2, y2, z2 = q2.a, q2.v.x, q2.v.y, q2.v.z
    return {
        a = a1 * a2 - x1 * x2 - y1 * y2 - z1 * z2,
        v = {
            x = a1 * x2 + x1 * a2 + y1 * z2 - z1 * y2,
            y = a1 * y2 - x1 * z2 + y1 * a2 + z1 * x2,
            z = a1 * z2 + x1 * y2 - y1 * x2 + z1 * a2
        }
    }
end

local function quatNorm(q)
    local m = math.sqrt(q.a * q.a + q.v.x * q.v.x + q.v.y * q.v.y + q.v.z * q.v.z)
    if m == 0 then
        return { a = 1, v = { x = 0, y = 0, z = 0 } }
    end
    return { a = q.a / m, v = { x = q.v.x / m, y = q.v.y / m, z = q.v.z / m } }
end

local function quatRotate(q, v)
    local r = quatMul(quatMul(q, { a = 0, v = { x = v.x, y = v.y, z = v.z } }), quatConj(q))
    return { x = r.v.x, y = r.v.y, z = r.v.z }
end

local function worldToLocal(q, v)
    return quatRotate(quatConj(q), v)
end

local function findModemSide()
    for _, s in ipairs(peripheral.getNames()) do
        if peripheral.getType(s) == "modem" then
            return s
        end
    end
    return nil
end

local function findBridgeSide()
    for _, s in ipairs(peripheral.getNames()) do
        local p = peripheral.wrap(s)
        if p and type(p.sendLinkSignal) == "function" then
            return s
        end
    end
    return nil
end

local modemSide = findModemSide()
if not modemSide then error("NO MODEM") end

local bridgeSide = findBridgeSide()
if not bridgeSide then error("NO BRIDGE") end

if not rednet.isOpen(modemSide) then
    rednet.open(modemSide)
end

local bridge = peripheral.wrap(bridgeSide)

local CH = {
    pitchDown = { block = "minecraft:red_glazed_terracotta", item = "minecraft:red_glazed_terracotta" },
    pitchUp   = { block = "minecraft:orange_glazed_terracotta", item = "minecraft:orange_glazed_terracotta" },
    rollLeft  = { block = "minecraft:yellow_glazed_terracotta", item = "minecraft:yellow_glazed_terracotta" },
    rollRight = { block = "minecraft:lime_glazed_terracotta", item = "minecraft:lime_glazed_terracotta" },
    throttle  = { block = "minecraft:oak_planks", item = "minecraft:coal_block" }
}

local function sig(ch, p)
    p = clamp(math.floor(p + 0.5), 0, 15)
    bridge.sendLinkSignal(ch.block, ch.item, p)
end

local out = {
    pm = "none",
    pp = 0,
    rm = "none",
    rp = 0,
    th = -1
}

local function stopPitch()
    sig(CH.pitchDown, 0)
    sig(CH.pitchUp, 0)
    out.pm = "none"
    out.pp = 0
end

local function stopRoll()
    sig(CH.rollLeft, 0)
    sig(CH.rollRight, 0)
    out.rm = "none"
    out.rp = 0
end

local function setPitchUp(p)
    p = clamp(p, 0, 15)
    if p <= 0 then
        stopPitch()
        return
    end
    if out.pm ~= "up" or out.pp ~= p then
        sig(CH.pitchDown, 0)
        sig(CH.pitchUp, p)
        out.pm = "up"
        out.pp = p
    end
end

local function setPitchDown(p)
    p = clamp(p, 0, 15)
    if p <= 0 then
        stopPitch()
        return
    end
    if out.pm ~= "down" or out.pp ~= p then
        sig(CH.pitchUp, 0)
        sig(CH.pitchDown, p)
        out.pm = "down"
        out.pp = p
    end
end

local function setRollLeft(p)
    p = clamp(p, 0, 15)
    if p <= 0 then
        stopRoll()
        return
    end
    if out.rm ~= "left" or out.rp ~= p then
        sig(CH.rollRight, 0)
        sig(CH.rollLeft, p)
        out.rm = "left"
        out.rp = p
    end
end

local function setRollRight(p)
    p = clamp(p, 0, 15)
    if p <= 0 then
        stopRoll()
        return
    end
    if out.rm ~= "right" or out.rp ~= p then
        sig(CH.rollLeft, 0)
        sig(CH.rollRight, p)
        out.rm = "right"
        out.rp = p
    end
end

local function setThrottle(p)
    p = clamp(math.floor(p + 0.5), 0, 15)
    if out.th ~= p then
        sig(CH.throttle, p)
        out.th = p
    end
end

local function stopAll()
    stopPitch()
    stopRoll()
    setThrottle(0)
end

local function loadProfile()
    if not fs.exists(CFG.profileFile) then
        local d = {
            cruiseAlt = CFG.cruiseAlt,
            finalOffset = CFG.finalOffset,
            yawGain = 7.0,
            pitchGain = 8.0,
            cruiseRollLimit = CFG.cruiseRollLimit,
            approachRollLimit = CFG.approachRollLimit,
            finalRollLimit = CFG.finalRollLimit,
            cruisePitchLimit = CFG.cruisePitchLimit,
            approachPitchLimit = CFG.approachPitchLimit,
            finalPitchLimit = CFG.finalPitchLimit,
            thrCruise = CFG.thrCruise,
            thrTurn = CFG.thrTurn,
            thrFinal = CFG.thrFinal,
            thrRecovery = CFG.thrRecovery
        }
        local f = fs.open(CFG.profileFile, "w")
        f.write(textutils.serialize(d))
        f.close()
        return d
    end

    local f = fs.open(CFG.profileFile, "r")
    if not f then error("PROFILE OPEN FAILED") end
    local ok, data = pcall(textutils.unserialize, f.readAll())
    f.close()
    if not ok or type(data) ~= "table" then error("PROFILE PARSE FAILED") end
    return data
end

local function saveProfile(p)
    local f = fs.open(CFG.profileFile, "w")
    if not f then return false end
    f.write(textutils.serialize(p))
    f.close()
    return true
end

local profile = loadProfile()

local function recvTarget()
    print("WAIT TARGET")
    local _, msg = rednet.receive(CFG.protocol)
    if type(msg) ~= "table" or msg.x == nil or msg.y == nil or msg.z == nil then
        error("BAD TARGET")
    end
    return vec(msg.x, msg.y, msg.z)
end

local function cruiseTargetAlt(py)
    local a = profile.cruiseAlt or CFG.cruiseAlt
    if py < CFG.cruiseMinAlt then
        a = CFG.cruiseMinAlt + 10
    elseif py > CFG.cruiseMaxAlt then
        a = CFG.cruiseMaxAlt - 10
    end
    return a
end

local function targetAlt(py, ty, dist)
    local cruise = cruiseTargetAlt(py)
    local final = ty + (profile.finalOffset or CFG.finalOffset)
    if dist > CFG.approachDist then
        return cruise
    end
    local t = clamp((CFG.approachDist - dist) / CFG.approachDist, 0, 1)
    t = t * t
    return lerp(cruise, final, t)
end

local function limitedRollPower(err, dist, mode)
    local g = profile.yawGain or 7.0
    local p = math.abs(err) * g
    local lim = profile.cruiseRollLimit or CFG.cruiseRollLimit
    if mode == "APPROACH" then lim = profile.approachRollLimit or CFG.approachRollLimit end
    if mode == "FINAL" then lim = profile.finalRollLimit or CFG.finalRollLimit end
    return clamp(math.floor(p + 0.5), 0, lim)
end

local function limitedPitchPower(err, dist, mode)
    local g = profile.pitchGain or 8.0
    local p = math.abs(err) * g
    local lim = profile.cruisePitchLimit or CFG.cruisePitchLimit
    if mode == "APPROACH" then lim = profile.approachPitchLimit or CFG.approachPitchLimit end
    if mode == "FINAL" then lim = profile.finalPitchLimit or CFG.finalPitchLimit end
    return clamp(math.floor(p + 0.5), 0, lim)
end

local function desiredThrottle(mode, dist, altError, speed, verticalSpeed)
    local base = profile.thrCruise or CFG.thrCruise
    if mode == "LAUNCH" then
        base = profile.thrRecovery or CFG.thrRecovery
    elseif mode == "APPROACH" then
        base = profile.thrTurn or CFG.thrTurn
    elseif mode == "FINAL" then
        base = profile.thrFinal or CFG.thrFinal
    elseif mode == "RECOVERY" then
        base = profile.thrRecovery or CFG.thrRecovery
    end

    local speedTarget = 0
    if mode == "LAUNCH" then
        speedTarget = 3.0
    elseif mode == "CRUISE" then
        speedTarget = 2.5
    elseif mode == "APPROACH" then
        speedTarget = 2.0
    elseif mode == "FINAL" then
        speedTarget = 1.4
    else
        speedTarget = 3.2
    end

    local speedErr = speedTarget - speed
    local t = base + speedErr * 2.1

    if altError < -15 then
        t = t + 1
    elseif altError > 12 then
        t = t + 1
    end

    if verticalSpeed < -2.5 then
        t = t + 1
    elseif verticalSpeed > 2.5 then
        t = t - 1
    end

    if dist < CFG.finalDist then
        t = math.min(t, profile.thrFinal or CFG.thrFinal)
    end

    return clamp(math.floor(t + 0.5), 3, CFG.thrMax)
end

local function render(mode, pose, target, dist, desiredAlt, yawErr, pitchErr, thr, speed, vSpeed)
    term.clear()
    term.setCursorPos(1, 1)
    print("CARGO AUTOPILOT")
    print("")
    print("MODE  " .. mode)
    print("DIST  " .. math.floor(dist))
    print("ALT   " .. math.floor(pose.position.y))
    print("TALT  " .. math.floor(desiredAlt))
    print("SPEED " .. math.floor(speed * 100) / 100)
    print("VSPD  " .. math.floor(vSpeed * 100) / 100)
    print("YERR  " .. math.floor(yawErr * 100) / 100)
    print("PERR  " .. math.floor(pitchErr * 100) / 100)
    print("THR   " .. thr)
    print("")
    print("TARGET")
    print(math.floor(target.x) .. " " .. math.floor(target.y) .. " " .. math.floor(target.z))
end

local function logLine(s)
    local f = fs.open(CFG.telemetryFile, "a")
    if not f then return end
    f.writeLine(s)
    f.close()
end

local function adaptGain(g, err, prevErr, power, lim)
    if prevErr ~= nil then
        if err * prevErr < 0 then
            g = g * 0.996
        end
        if math.abs(err) > math.abs(prevErr) and power >= lim * 0.80 then
            g = g * 1.002
        end
    end
    return clamp(g, 3.5, 10.0)
end

local function aimLoop(target)
    local smoothYaw = 0
    local smoothPitch = 0
    local smoothVel = vec(0, 0, 0)
    local lastPos = nil
    local lastYaw = nil
    local lastPitch = nil
    local state = "LAUNCH"
    local stateTicks = 0
    local stallTicks = 0
    local dirty = false
    local tickCounter = 0
    local lastSave = 0

    setThrottle(profile.thrLaunch or CFG.thrLaunch)
    sleep(1)

    while true do
        local pose = sublevel.getLogicalPose()
        if not pose or not pose.position or not pose.orientation then
            stopAll()
            error("BAD POSE")
        end

        local pos = pose.position
        local q = quatNorm(pose.orientation)
        local current = vec(pos.x, pos.y, pos.z)

        local rawVel = vec(0, 0, 0)
        if lastPos then
            rawVel = vmul(vsub(current, lastPos), 1 / CFG.tick)
        end
        smoothVel = lerpVec(smoothVel, rawVel, CFG.velSmooth)

        local speed = vlen(smoothVel)
        local vSpeed = smoothVel.y

        local predicted = vadd(current, vmul(smoothVel, CFG.leadTime))
        local delta = vsub(target, predicted)
        local dist = vlen(delta)

        local desiredAlt = targetAlt(pos.y, target.y, dist)
        local guided = vec(target.x, desiredAlt, target.z)
        local gdelta = vsub(guided, predicted)

        local localDelta = worldToLocal(q, gdelta)
        local yaw = math.atan2(localDelta.z, localDelta.x)
        local horiz = math.sqrt(localDelta.x * localDelta.x + localDelta.z * localDelta.z)
        local pitch = math.atan2(localDelta.y, horiz)

        smoothYaw = lerp(smoothYaw, yaw, CFG.yawSmooth)
        smoothPitch = lerp(smoothPitch, pitch, CFG.pitchSmooth)

        stateTicks = stateTicks + 1

        if state ~= "RECOVERY" then
            if pos.y < CFG.safeAlt then
                state = "RECOVERY"
                stateTicks = 0
            elseif dist < CFG.finalDist then
                state = "FINAL"
            elseif dist < CFG.approachDist then
                state = "APPROACH"
            elseif state == "LAUNCH" and stateTicks > CFG.launchTicks then
                state = "CRUISE"
            end
        else
            if pos.y > CFG.safeAlt + 12 and speed > CFG.recoveryMinSpeed and dist > 20 then
                state = (dist < CFG.finalDist) and "FINAL" or ((dist < CFG.approachDist) and "APPROACH" or "CRUISE")
                stateTicks = 0
                stallTicks = 0
            end
        end

        if speed < CFG.recoveryMinSpeed and dist > 30 then
            stallTicks = stallTicks + 1
        else
            stallTicks = 0
        end

        if stallTicks > CFG.recoveryStallTicks then
            state = "RECOVERY"
            stateTicks = 0
        end

        local rollLimit = CFG.cruiseRollLimit
        local pitchLimit = CFG.cruisePitchLimit
        local thr = profile.thrCruise or CFG.thrCruise

        if state == "LAUNCH" then
            thr = profile.thrLaunch or CFG.thrLaunch
            if pos.y < (profile.cruiseAlt or CFG.cruiseAlt) - 8 then
                local p = clamp(math.floor(4 + (profile.cruiseAlt - pos.y) * 0.05), 2, 6)
                setPitchUp(p)
            else
                stopPitch()
            end
            rollLimit = 4
            pitchLimit = 6

        elseif state == "CRUISE" then
            rollLimit = profile.cruiseRollLimit or CFG.cruiseRollLimit
            pitchLimit = profile.cruisePitchLimit or CFG.cruisePitchLimit
            thr = profile.thrCruise or CFG.thrCruise

        elseif state == "APPROACH" then
            rollLimit = profile.approachRollLimit or CFG.approachRollLimit
            pitchLimit = profile.approachPitchLimit or CFG.approachPitchLimit
            thr = profile.thrTurn or CFG.thrTurn

        elseif state == "FINAL" then
            rollLimit = profile.finalRollLimit or CFG.finalRollLimit
            pitchLimit = profile.finalPitchLimit or CFG.finalPitchLimit
            thr = profile.thrFinal or CFG.thrFinal

        elseif state == "RECOVERY" then
            rollLimit = 3
            pitchLimit = 10
            thr = profile.thrRecovery or CFG.thrRecovery
        end

        local altError = desiredAlt - pos.y
        local rollPower = limitedRollPower(smoothYaw, dist, state)
        local pitchPower = limitedPitchPower(smoothPitch, dist, state)

        if state == "RECOVERY" then
            stopRoll()
            if altError > 0 then
                setPitchUp(math.min(10, pitchPower + 3))
            else
                setPitchUp(6)
            end
            thr = math.max(thr, profile.thrRecovery or CFG.thrRecovery)
        else
            if smoothYaw > CFG.yawDead then
                setRollRight(rollPower)
            elseif smoothYaw < -CFG.yawDead then
                setRollLeft(rollPower)
            else
                stopRoll()
            end

            if state == "FINAL" then
                local finalAlt = target.y + (profile.finalOffset or CFG.finalOffset)
                local diveErr = finalAlt - pos.y
                local divePow = clamp(math.floor(math.abs(diveErr) * 0.55) + 4, 3, pitchLimit)
                if diveErr > 0 then
                    setPitchUp(divePow)
                else
                    setPitchDown(divePow)
                end
                thr = math.min(thr, profile.thrFinal or CFG.thrFinal)
            else
                if smoothPitch > CFG.pitchDead then
                    setPitchUp(clamp(pitchPower, 0, pitchLimit))
                elseif smoothPitch < -CFG.pitchDead then
                    setPitchDown(clamp(pitchPower, 0, pitchLimit))
                else
                    stopPitch()
                end
            end
        end

        local speedTarget = 0
        if state == "LAUNCH" then
            speedTarget = 3.0
        elseif state == "CRUISE" then
            speedTarget = 2.5
        elseif state == "APPROACH" then
            speedTarget = 2.0
        elseif state == "FINAL" then
            speedTarget = 1.4
        else
            speedTarget = 3.2
        end

        local speedErr = speedTarget - speed
        thr = thr + speedErr * 2.1

        if altError < -15 or vSpeed < -2.5 then
            thr = thr + 1
        elseif altError > 12 then
            thr = thr + 1
        end

        if dist < CFG.finalDist then
            thr = math.min(thr, profile.thrFinal or CFG.thrFinal)
        end

        setThrottle(clamp(math.floor(thr + 0.5), 3, CFG.thrMax))

        tickCounter = tickCounter + 1

        if tickCounter % 20 == 0 then
            if lastYaw ~= nil then
                profile.yawGain = adaptGain(profile.yawGain or 7.0, smoothYaw, lastYaw, rollPower, rollLimit)
                profile.pitchGain = adaptGain(profile.pitchGain or 8.0, smoothPitch, lastPitch, pitchPower, pitchLimit)
                dirty = true
            end
            lastYaw = smoothYaw
            lastPitch = smoothPitch
        end

        if dirty and (tickCounter - lastSave) > 100 then
            saveProfile(profile)
            lastSave = tickCounter
            dirty = false
        end

        render(state, pose, target, dist, desiredAlt, smoothYaw, smoothPitch, out.th, speed, vSpeed)

        logLine(string.format(
            "m=%s d=%.2f alt=%.2f talt=%.2f spd=%.2f vspd=%.2f yaw=%.4f pitch=%.4f thr=%d",
            state, dist, pos.y, desiredAlt, speed, vSpeed, smoothYaw, smoothPitch, out.th
        ))

        lastPos = current
        sleep(CFG.tick)
    end
end

local function main()
    term.clear()
    term.setCursorPos(1, 1)
    print("CARGO AUTOPILOT BOOT")
    print("")
    print("MODEM  " .. modemSide)
    print("BRIDGE " .. bridgeSide)
    print("")

    local target = recvTarget()
    print("TARGET OK")
    print(textutils.serialize(target))
    sleep(0.5)

    aimLoop(target)
end

local ok, err = pcall(main)
if not ok then
    stopAll()
    term.clear()
    term.setCursorPos(1, 1)
    print("AUTOPILOT ERROR")
    print("")
    print(err)
    error(err)
end
