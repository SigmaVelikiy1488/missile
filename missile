rednet.open("top")

local bridge = peripheral.wrap("right")

print("WAITING TARGET")

local _,msg = rednet.receive("geran")

local TX = msg.x
local TY = msg.y
local TZ = msg.z

local CRUISE_ALT = 125
local DESCENT_DIST = 120
local SAFE_BANK = 0.35
local LOOP = 0.05

local rollState = "none"
local pitchState = "none"

local function sig(a,b,p)
 bridge.sendLinkSignal(a,b,p)
end

local function stopAll()

 sig("minecraft:red_wool","minecraft:netherite_ingot",0)
 sig("minecraft:white_wool","minecraft:iron_ingot",0)

 sig("minecraft:orange_wool","minecraft:copper_ingot",0)
 sig("minecraft:lime_wool","minecraft:gold_ingot",0)

end

local function setPitch(state)

 if pitchState == state then
  return
 end

 pitchState = state

 sig("minecraft:red_wool","minecraft:netherite_ingot",0)
 sig("minecraft:white_wool","minecraft:iron_ingot",0)

 sig("minecraft:orange_wool","minecraft:copper_ingot",0)
 sig("minecraft:lime_wool","minecraft:gold_ingot",0)

 if state == "up" then

  sig("minecraft:red_wool","minecraft:netherite_ingot",15)
  sig("minecraft:white_wool","minecraft:iron_ingot",15)

 elseif state == "down" then

  sig("minecraft:orange_wool","minecraft:copper_ingot",15)
  sig("minecraft:lime_wool","minecraft:gold_ingot",15)

 end

end

local function setRoll(state)

 if rollState == state then
  return
 end

 rollState = state

 sig("minecraft:red_wool","minecraft:netherite_ingot",0)
 sig("minecraft:white_wool","minecraft:iron_ingot",0)

 sig("minecraft:orange_wool","minecraft:copper_ingot",0)
 sig("minecraft:lime_wool","minecraft:gold_ingot",0)

 if state == "left" then

  sig("minecraft:orange_wool","minecraft:copper_ingot",15)
  sig("minecraft:white_wool","minecraft:iron_ingot",15)

 elseif state == "right" then

  sig("minecraft:red_wool","minecraft:netherite_ingot",15)
  sig("minecraft:lime_wool","minecraft:gold_ingot",15)

 end

end

while true do

 local pose = sublevel.getLogicalPose()

 local px = pose.position.x
 local py = pose.position.y
 local pz = pose.position.z

 local ox = pose.orientation.v.x
 local oy = pose.orientation.v.y

 local dx = TX - px
 local dy = TY - py
 local dz = TZ - pz

 local dist =
  math.sqrt(dx*dx + dy*dy + dz*dz)

 local flat =
  math.sqrt(dx*dx + dz*dz)

 local targetYaw =
  math.atan2(dz,dx)

 local currentYaw =
  oy * 2

 local yawError =
  targetYaw - currentYaw

 while yawError > math.pi do
  yawError = yawError - math.pi*2
 end

 while yawError < -math.pi do
  yawError = yawError + math.pi*2
 end

 local targetAlt = CRUISE_ALT

 if dist < DESCENT_DIST then
  targetAlt = TY + 5
 end

 local altError =
  targetAlt - py

 if dist > DESCENT_DIST then

  if altError > 8 then
   setPitch("up")
  elseif altError < -8 then
   setPitch("down")
  else
   setPitch("none")
  end

 else

  if py > TY + 5 then
   setPitch("down")
  else
   setPitch("none")
  end

 end

 if py < 70 then

  if ox > SAFE_BANK then
   setRoll("left")

  elseif ox < -SAFE_BANK then
   setRoll("right")

  else
   setRoll("none")
  end

 else

  if yawError > 0.18 then
   setRoll("right")

  elseif yawError < -0.18 then
   setRoll("left")

  else
   setRoll("none")
  end

 end

 term.clear()
 term.setCursorPos(1,1)

 print("GERAN")
 print("")
 print("DIST "..math.floor(dist))
 print("ALT "..math.floor(py))
 print("")
 print("ROLL "..math.floor(ox*100)/100)
 print("YAW "..math.floor(yawError*100)/100)
 print("")
 print("MODE")

 if dist > DESCENT_DIST then
  print("CRUISE")
 else
  print("DESCENT")
 end

 sleep(LOOP)

end
